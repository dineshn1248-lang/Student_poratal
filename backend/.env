# ─────────────────────────────────────────────────────────────────────────────
# .env  –  Environment configuration for UUCMS Backend
# Copy this file to the backend/ directory and fill in real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=uucms-super-secret-key-change-in-prod

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///instance/student_portal.db

# MySQL (uncomment and fill in when migrating):
# DATABASE_URL=mysql+mysqlconnector://root:YOUR_PASSWORD@127.0.0.1:3306/student_portal

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# For Gmail: enable "App Passwords" in Google Account > Security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_college_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=UUCMS Academic Portal <your_college_email@gmail.com>

# ── Twilio (SMS + WhatsApp) ───────────────────────────────────────────────────
# Sign up at https://www.twilio.com and get your credentials
